{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/lib",
    "rootDir": ".",
    "strict": true,
    "types": ["node", "chrome"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "lib/types.ts",
    "lib/path-utils.ts",
    "lib/routing.ts",
    "lib/discovery.ts",
    "lib/capture.ts",
    "lib/element-context.ts",
    "lib/highlight-draw.ts",
    "lib/marquee.ts",
    "lib/pin-position.ts",
    "lib/review-notes.ts",
    "lib/error-toast.ts",
    "lib/payload-size.ts",
    "lib/thumbnail-number.ts",
    "lib/test/**/*.ts",
    "entrypoints/review.content/card-state.ts"
  ],
  "exclude": [
    "lib/storage.ts"
  ]
}
