# WXT build output
.output/

# Host build output
dist/

# Extension build (legacy path)
extension/build/
*.zip
release/

# Dependencies
node_modules/

# WXT generated files (regenerated by postinstall/wxt prepare)
.wxt/

# Notes captured at runtime (this is user content, never commit)
notes/
!notes/.gitkeep

# Allow test fixture notes (not runtime content)
!test/fixtures/notes/
!test/fixtures/notes/**

# Logs / runtime
*.log
.stikfix-token
.DS_Store
Thumbs.db

# Editor / local agent config (never publish internal agent identity files)
.vscode/
.idea/
# Ignore .claude/ EXCEPT the shipped review-notes skill wrapper — it is part of the product (SKILL-01/D-01).
# Walk-down form (a parent dir ignored with a trailing slash cannot be re-included).
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/review-notes/

# Private business/strategy docs — never publish to the public MIT repo
private/

# GSD planning is committed; nothing to ignore there

# Stray JS files that tsc may emit next to source files (compiled output belongs in dist/)
lib/*.js
lib/test/*.js

# Extension signing keys — private key MUST NEVER be committed (only .keys/manifest-key.txt
# and .keys/extension-id.txt are committed as they are derived public data)
.keys/*.pem
.keys/*.p12
.keys/*.key
graphify-out/

# Local planning scratch (todo.md / lessons.md) — not a deliverable
tasks/
